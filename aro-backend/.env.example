# ARO Backend — Environment Variables
# Copy this to .env and fill in the values

# PostgreSQL connection string from Railway
DATABASE_URL=postgresql://user:password@host:port/database

# Secret key for JWT tokens (use a long random string)
JWT_SECRET=cambia_esto_por_una_clave_muy_secreta_aleatoria_larga

# Node environment
NODE_ENV=production

# Port (Railway sets this automatically)
PORT=3000

# Frontend URL (for CORS) — set to your Railway frontend URL or '*' for dev
FRONTEND_URL=*
